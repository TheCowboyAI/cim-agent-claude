{
  "dashboard": {
    "id": null,
    "title": "CIM Claude Adapter - Production Dashboard",
    "tags": ["cim", "claude", "adapter", "production"],
    "timezone": "UTC",
    "panels": [
      {
        "id": 1,
        "title": "System Overview",
        "type": "row",
        "collapsed": false,
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
        "panels": []
      },
      {
        "id": 2,
        "title": "Service Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"cim-claude-adapter\"}",
            "legendFormat": "CIM Claude Adapter",
            "refId": "A"
          },
          {
            "expr": "up{job=\"nats-server\"}",
            "legendFormat": "NATS Server",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            },
            "mappings": [
              {"options": {"0": {"text": "Down"}}, "type": "value"},
              {"options": {"1": {"text": "Up"}}, "type": "value"}
            ]
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1}
      },
      {
        "id": 3,
        "title": "Request Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(cim_claude_adapter_requests_total[5m]))",
            "legendFormat": "Requests/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 100},
                {"color": "red", "value": 1000}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1}
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(cim_claude_adapter_errors_total[5m]))",
            "legendFormat": "Errors/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "eps",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.1},
                {"color": "red", "value": 1}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1}
      },
      {
        "id": 5,
        "title": "Performance Metrics",
        "type": "row",
        "collapsed": false,
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
        "panels": []
      },
      {
        "id": 6,
        "title": "Response Time Distribution",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(cim_claude_adapter_request_duration_seconds_bucket[5m]))",
            "legendFormat": "50th percentile",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(cim_claude_adapter_request_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(cim_claude_adapter_request_duration_seconds_bucket[5m]))",
            "legendFormat": "99th percentile",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Response Time (seconds)",
            "logBase": 1,
            "min": null,
            "max": null,
            "unit": "s"
          },
          {
            "label": "",
            "logBase": 1,
            "min": null,
            "max": null
          }
        ],
        "xAxis": {
          "mode": "time",
          "name": null,
          "values": [],
          "show": true
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10}
      },
      {
        "id": 7,
        "title": "Throughput Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(cim_claude_adapter_requests_total[1m]))",
            "legendFormat": "Total Requests/min",
            "refId": "A"
          },
          {
            "expr": "sum(rate(cim_claude_adapter_requests_total{status=\"success\"}[1m]))",
            "legendFormat": "Successful Requests/min",
            "refId": "B"
          },
          {
            "expr": "sum(rate(cim_claude_adapter_errors_total[1m]))",
            "legendFormat": "Errors/min",
            "refId": "C"
          }
        ],
        "yAxes": [
          {
            "label": "Requests per minute",
            "logBase": 1,
            "min": 0,
            "unit": "rpm"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10}
      },
      {
        "id": 8,
        "title": "Resource Usage",
        "type": "row",
        "collapsed": false,
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
        "panels": []
      },
      {
        "id": 9,
        "title": "CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=\"cim-claude-adapter\"}[5m]) * 100",
            "legendFormat": "CPU Usage %",
            "refId": "A"
          },
          {
            "expr": "avg(100 - (avg by (instance) (irate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[5m])) * 100))",
            "legendFormat": "System CPU %",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "CPU Percentage",
            "min": 0,
            "max": 100,
            "unit": "percent"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 19}
      },
      {
        "id": 10,
        "title": "Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"cim-claude-adapter\"} / 1024 / 1024",
            "legendFormat": "RSS Memory (MB)",
            "refId": "A"
          },
          {
            "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"})) * 100",
            "legendFormat": "System Memory %",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Memory",
            "min": 0,
            "unit": "bytes"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 19}
      },
      {
        "id": 11,
        "title": "Network I/O",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total{job=\"node-exporter\",device!=\"lo\"}[5m]) * 8",
            "legendFormat": "Inbound {{device}}",
            "refId": "A"
          },
          {
            "expr": "rate(node_network_transmit_bytes_total{job=\"node-exporter\",device!=\"lo\"}[5m]) * 8",
            "legendFormat": "Outbound {{device}}",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Bits per second",
            "min": 0,
            "unit": "bps"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 19}
      },
      {
        "id": 12,
        "title": "NATS Metrics",
        "type": "row",
        "collapsed": false,
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
        "panels": []
      },
      {
        "id": 13,
        "title": "NATS Connections",
        "type": "graph",
        "targets": [
          {
            "expr": "nats_server_connections",
            "legendFormat": "Active Connections",
            "refId": "A"
          },
          {
            "expr": "nats_server_subscriptions",
            "legendFormat": "Subscriptions",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Count",
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 28}
      },
      {
        "id": 14,
        "title": "NATS Message Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(nats_server_messages_in_total[5m])",
            "legendFormat": "Messages In/sec",
            "refId": "A"
          },
          {
            "expr": "rate(nats_server_messages_out_total[5m])",
            "legendFormat": "Messages Out/sec",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Messages per second",
            "min": 0,
            "unit": "mps"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 28}
      },
      {
        "id": 15,
        "title": "JetStream Storage",
        "type": "graph",
        "targets": [
          {
            "expr": "nats_jetstream_storage_bytes_used",
            "legendFormat": "Storage Used",
            "refId": "A"
          },
          {
            "expr": "nats_jetstream_storage_bytes_limit",
            "legendFormat": "Storage Limit",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Bytes",
            "min": 0,
            "unit": "bytes"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 28}
      },
      {
        "id": 16,
        "title": "Business Metrics",
        "type": "row",
        "collapsed": false,
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
        "panels": []
      },
      {
        "id": 17,
        "title": "Conversations Started",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(cim_claude_conversations_started_total[1h]))",
            "legendFormat": "Conversations/hour",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 37}
      },
      {
        "id": 18,
        "title": "Messages Processed",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(cim_claude_messages_processed_total[1h]))",
            "legendFormat": "Messages/hour",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"mode": "palette-classic"}
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 37}
      },
      {
        "id": 19,
        "title": "Token Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(cim_claude_tokens_used_total[5m]))",
            "legendFormat": "Tokens/sec",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Tokens per second",
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 37}
      },
      {
        "id": 20,
        "title": "Attachment Processing",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(cim_claude_attachments_processed_total[5m]))",
            "legendFormat": "Attachments/sec",
            "refId": "A"
          },
          {
            "expr": "sum(rate(cim_claude_attachments_failed_total[5m]))",
            "legendFormat": "Failed/sec",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Attachments per second",
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 37}
      },
      {
        "id": 21,
        "title": "Alerts & Security",
        "type": "row",
        "collapsed": false,
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 45},
        "panels": []
      },
      {
        "id": 22,
        "title": "Active Alerts",
        "type": "alertlist",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 46},
        "options": {
          "showOptions": "current",
          "maxItems": 20,
          "sortOrder": "alphabetical",
          "dashboardAlerts": false,
          "alertInstanceLabelFilter": "",
          "dashboardTitle": "",
          "folderId": null
        }
      },
      {
        "id": 23,
        "title": "Security Events",
        "type": "logs",
        "targets": [
          {
            "expr": "{job=\"systemd-journal\", unit=\"cim-claude-adapter.service\"} |~ \"auth_failed|security_violation|suspicious_activity\"",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": false,
          "showCommonLabels": false,
          "wrapLogMessage": false,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "dedupStrategy": "none",
          "sortOrder": "Descending"
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 46}
      },
      {
        "id": 24,
        "title": "Cluster Status",
        "type": "row",
        "collapsed": false,
        "gridPos": {"h": 1, "w": 24, "x": 0, "y": 54},
        "panels": []
      },
      {
        "id": 25,
        "title": "Cluster Nodes",
        "type": "stat",
        "targets": [
          {
            "expr": "cim_cluster_size",
            "legendFormat": "Active Nodes",
            "refId": "A"
          },
          {
            "expr": "sum(cim_cluster_node_is_master)",
            "legendFormat": "Master Nodes",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 2},
                {"color": "green", "value": 3}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 55}
      },
      {
        "id": 26,
        "title": "Node Health",
        "type": "graph",
        "targets": [
          {
            "expr": "cim_cluster_health_check_status",
            "legendFormat": "{{node}}",
            "refId": "A"
          }
        ],
        "yAxes": [
          {
            "label": "Health Status",
            "min": 0,
            "max": 1
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 55}
      },
      {
        "id": 27,
        "title": "Backup Status",
        "type": "graph",
        "targets": [
          {
            "expr": "cim_claude_backup_latest_timestamp",
            "legendFormat": "Last Backup",
            "refId": "A"
          },
          {
            "expr": "time() - cim_claude_backup_latest_timestamp",
            "legendFormat": "Time Since Last Backup (seconds)",
            "refId": "B"
          }
        ],
        "yAxes": [
          {
            "label": "Timestamp / Age",
            "unit": "dateTimeAsIso"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 55}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
      "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
    },
    "refresh": "30s",
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": "-- Grafana --",
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        },
        {
          "datasource": "Prometheus",
          "enable": true,
          "expr": "ALERTS{alertname=~\"CIM.*\"}",
          "iconColor": "red",
          "name": "CIM Alerts",
          "step": "60s",
          "tagKeys": "alertname,severity",
          "textFormat": "{{alertname}}: {{description}}",
          "titleFormat": "Alert"
        }
      ]
    },
    "templating": {
      "list": [
        {
          "allValue": null,
          "current": {
            "selected": false,
            "text": "All",
            "value": "$__all"
          },
          "datasource": "Prometheus",
          "definition": "label_values(up{job=\"cim-claude-adapter\"}, instance)",
          "hide": 0,
          "includeAll": true,
          "label": "Instance",
          "multi": true,
          "name": "instance",
          "options": [],
          "query": "label_values(up{job=\"cim-claude-adapter\"}, instance)",
          "refresh": 1,
          "regex": "",
          "skipUrlSync": false,
          "sort": 0,
          "tagValuesQuery": "",
          "tags": [],
          "tagsQuery": "",
          "type": "query",
          "useTags": false
        },
        {
          "allValue": null,
          "current": {
            "selected": false,
            "text": "5m",
            "value": "5m"
          },
          "hide": 0,
          "includeAll": false,
          "label": "Rate Interval",
          "multi": false,
          "name": "rate_interval",
          "options": [
            {
              "selected": false,
              "text": "1m",
              "value": "1m"
            },
            {
              "selected": true,
              "text": "5m",
              "value": "5m"
            },
            {
              "selected": false,
              "text": "10m",
              "value": "10m"
            },
            {
              "selected": false,
              "text": "30m",
              "value": "30m"
            }
          ],
          "query": "1m,5m,10m,30m",
          "skipUrlSync": false,
          "type": "custom"
        }
      ]
    },
    "links": [
      {
        "asDropdown": false,
        "icon": "external link",
        "includeVars": false,
        "keepTime": false,
        "tags": ["cim", "claude"],
        "targetBlank": false,
        "title": "CIM Claude Dashboards",
        "tooltip": "",
        "type": "dashboards",
        "url": ""
      }
    ],
    "description": "Comprehensive monitoring dashboard for CIM Claude Adapter production deployment. Includes system metrics, business KPIs, security monitoring, and cluster status.",
    "editable": true,
    "gnetId": null,
    "graphTooltip": 0,
    "hideControls": false,
    "schemaVersion": 27,
    "style": "dark",
    "tags": ["cim", "claude", "adapter", "production", "monitoring"],
    "version": 1
  }
}